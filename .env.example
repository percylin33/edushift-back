# =============================================================================
# EduShift - plantilla maestra de variables de entorno
#
# Uso:
#   - Desarrollo local : cp .env.dev.example  .env
#   - Producción       : cp .env.prod.example .env  (rellenar valores reales)
#
# IMPORTANTE:
#   - NO commitear .env, .env.dev, .env.prod (ver .gitignore)
#   - Secretos en producción: gestor de secretos (Vault, AWS Secrets Manager,
#     Doppler, GitHub Actions secrets, etc.). Este archivo es solo plantilla.
# =============================================================================

# -----------------------------------------------------------------------------
# Spring / servidor
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=
APP_VERSION=latest
BACKEND_HOST_PORT=8080
SERVER_CONTEXT_PATH=/api

# Frontend / CORS / base URL
APP_BASE_URL=
FRONTEND_URL=
CORS_ALLOWED_ORIGINS=
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
DB_NAME=edushift
DB_USER=edushift
DB_PASSWORD=
DB_SCHEMA=edushift
DB_SSL_MODE=disable
DB_HOST_PORT=5432

# Hikari (pool)
HIKARI_MINIMUM_IDLE=10
HIKARI_MAXIMUM_POOL_SIZE=30

# Flyway
FLYWAY_ENABLED=true
FLYWAY_SCHEMAS=edushift
FLYWAY_DEFAULT_SCHEMA=edushift

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false
REDIS_KEY_PREFIX=edushift:
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=allkeys-lru
REDIS_HOST_PORT=6379

# -----------------------------------------------------------------------------
# JWT (mín 32 caracteres para HS256)
# Generar: openssl rand -base64 48
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_ISSUER=edushift
JWT_AUDIENCE=edushift-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# -----------------------------------------------------------------------------
# OpenRouter (módulo AI)
# https://openrouter.ai/keys
# -----------------------------------------------------------------------------
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=
OPENROUTER_TITLE=EduShift
OPENROUTER_TIMEOUT=30s
OPENROUTER_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# Firebase (notificaciones FCM, opcionalmente auth)
# Usar UNA de:
#   - FIREBASE_CREDENTIALS_JSON (JSON del service-account, ideal en contenedor)
#   - FIREBASE_CREDENTIALS_PATH (ruta al archivo, montado como secret)
#
# EduShift dedicated project: project-1ecb3cb0-5e49-49b2-8e5
# (separado del proyecto temporal cd-store-529c3 que aloja un ecommerce).
# El bucket real se crea al provisionar Storage en Firebase Console.
# -----------------------------------------------------------------------------
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_JSON=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_WEB_API_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# Files / Storage provider (Sprint 7a / BE-7a.0, docs/infra/firebase.md)
#
# STORAGE_PROVIDER        : LOCAL_FS (dev/test) | FIREBASE (prod/staging).
#                            Un valor desconocido → la app NO arranca.
# STORAGE_MAX_FILE_SIZE   : tope por archivo (default 25 MB).
# STORAGE_LOCAL_FS_ROOT   : raíz de blobs cuando LOCAL_FS.
# STORAGE_LOCAL_FS_SERVE_FROM_CONTROLLER : true = download por el BE (bearer);
#                                          false = 302 a signed URL (FIREBASE).
# STORAGE_FIREBASE_BUCKET : bucket GCS (default: ${FIREBASE_STORAGE_BUCKET}).
# STORAGE_FIREBASE_CREDENTIALS_JSON / _PATH : mismas reglas que FIREBASE_*.
# STORAGE_FIREBASE_SIGNED_URL_TTL : TTL de los signed URLs en segundos.
#
# Para activar Firebase en staging/prod:
#   STORAGE_PROVIDER=FIREBASE
#   STORAGE_FIREBASE_BUCKET=edushift-<env>-<region>
#   STORAGE_FIREBASE_CREDENTIALS_JSON='<service-account JSON>'
#   STORAGE_LOCAL_FS_SERVE_FROM_CONTROLLER=false
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=LOCAL_FS
STORAGE_MAX_FILE_SIZE_BYTES=26214400
STORAGE_LOCAL_FS_ROOT=./edushift-storage
STORAGE_LOCAL_FS_SERVE_FROM_CONTROLLER=true
STORAGE_FIREBASE_BUCKET=
STORAGE_FIREBASE_CREDENTIALS_JSON=
STORAGE_FIREBASE_CREDENTIALS_PATH=
STORAGE_FIREBASE_SIGNED_URL_TTL=900

# -----------------------------------------------------------------------------
# Logging (routing y rotación viven en logback-spring.xml; aquí solo niveles)
# Categorías SLF4J: edushift.security | .requests | .exceptions | .ai | .audit
# -----------------------------------------------------------------------------
LOG_PATH=./logs
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
# Tuning fino (opcional)
APP_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=INFO
SQL_LOGGING_ENABLED=false
SQL_LOGGING_LEVEL=WARN
SQL_BIND_LOGGING_LEVEL=WARN
HIKARI_LOG_LEVEL=INFO
FLYWAY_LOG_LEVEL=INFO
REDIS_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# JVM / debug
# -----------------------------------------------------------------------------
JAVA_OPTS=-Xms256m -Xmx768m
DEBUG_PORT=5005
