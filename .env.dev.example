# =============================================================================
# EduShift - desarrollo local (cp .env.dev.example .env)
# Defaults seguros para desarrollo. NO commitear .env.
# =============================================================================

SPRING_PROFILES_ACTIVE=dev
APP_VERSION=dev
BACKEND_HOST_PORT=8080
SERVER_CONTEXT_PATH=/api

# Frontend / CORS
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4200
CORS_ALLOW_CREDENTIALS=true

# PostgreSQL (contenedor docker-compose)
DB_NAME=edushift
DB_USER=edushift
DB_PASSWORD=edushift
DB_SCHEMA=edushift
DB_SSL_MODE=disable
DB_HOST_PORT=5432

# Hikari (dev: pool pequeño)
HIKARI_MINIMUM_IDLE=2
HIKARI_MAXIMUM_POOL_SIZE=5

# Flyway
FLYWAY_ENABLED=true
FLYWAY_SCHEMAS=edushift
FLYWAY_DEFAULT_SCHEMA=edushift

# Redis (dev: sin password en el contenedor de override)
REDIS_PASSWORD=
REDIS_SSL_ENABLED=false
REDIS_KEY_PREFIX=edushift:
REDIS_MAXMEMORY=128mb
REDIS_HOST_PORT=6379

# JWT (dev) - secreto generado solo para desarrollo. Generar uno nuevo con:
#   openssl rand -base64 48
JWT_SECRET=dev-only-change-me-with-openssl-rand-base64-48-chars-min
JWT_ISSUER=edushift-dev
JWT_AUDIENCE=edushift-clients-dev
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# OpenRouter (desactivado por defecto en dev)
OPENROUTER_ENABLED=false
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=http://localhost:5173

# Firebase (desactivado por defecto en dev)
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# JVM
JAVA_OPTS=-Xms256m -Xmx512m
DEBUG_PORT=5005

# -----------------------------------------------------------------------------
# Logging (dev: consola legible con colores)
# -----------------------------------------------------------------------------
LOG_PATH=./logs
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
APP_LOG_LEVEL=DEBUG
SECURITY_LOG_LEVEL=DEBUG
SQL_LOGGING_ENABLED=true
SQL_LOGGING_LEVEL=DEBUG
SQL_BIND_LOGGING_LEVEL=TRACE
HIKARI_LOG_LEVEL=INFO
FLYWAY_LOG_LEVEL=DEBUG
REDIS_LOG_LEVEL=INFO
