# =============================================================================
# EduShift - git attributes
# Garantiza que scripts del proyecto (mvnw, shell, etc.) salen del repo con
# el bit de ejecución +x en checkout, evitando "Permission denied" en Docker.
# =============================================================================

# Maven Wrapper (Maven los requiere ejecutables)
mvnw        text eol=lf executable
mvnw.cmd    text eol=crlf

# Otros scripts shell futuros
*.sh        text eol=lf executable
