{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://edushift.com/schemas/ai/session-generator.v1.json",
  "title": "SessionGeneratorOutput",
  "description": "Strict JSON contract for the BE-8.1 'POST /v1/ai/generate-session' LLM output. Aligned to the MINEDU Perú lesson template (INICIO / DESARROLLO / CIERRE). The shape mirrors GenerateSessionResponse 1:1 so the parser is a straight Jackson deserialisation after validation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "activities",
    "resources",
    "evaluationCriteria"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 200
    },
    "summary": {
      "type": "string",
      "minLength": 20,
      "maxLength": 1000
    },
    "activities": {
      "type": "array",
      "minItems": 3,
      "maxItems": 8,
      "items": { "$ref": "#/$defs/Activity" }
    },
    "resources": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": { "$ref": "#/$defs/Resource" }
    },
    "evaluationCriteria": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": { "$ref": "#/$defs/EvaluationCriterion" }
    },
    "competencyRefs": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "capacityRefs": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    }
  },
  "$defs": {
    "Activity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["phase", "name", "durationMinutes", "description"],
      "properties": {
        "phase": {
          "type": "string",
          "enum": ["INICIO", "DESARROLLO", "CIERRE"]
        },
        "name": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "durationMinutes": {
          "type": "integer",
          "minimum": 5,
          "maximum": 180
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "maxLength": 1000
        }
      }
    },
    "Resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "title", "description"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["TEXT", "VIDEO", "AUDIO", "IMAGE", "INTERACTIVE", "OTHER"]
        },
        "title": {
          "type": "string",
          "minLength": 2,
          "maxLength": 200
        },
        "url": {
          "type": ["string", "null"],
          "maxLength": 500
        },
        "description": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500
        }
      }
    },
    "EvaluationCriterion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "weight", "description"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120
        },
        "weight": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "description": {
          "type": "string",
          "minLength": 5,
          "maxLength": 500
        }
      }
    }
  }
}
