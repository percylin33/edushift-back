# =============================================================================
# EduShift - producción (cp .env.prod.example .env y rellenar)
#
# REGLAS:
#   - Todos los <REQUIRED> deben venir de un gestor de secretos.
#   - NO commitear .env con valores reales.
#   - Rotar JWT_SECRET y credenciales periódicamente.
# =============================================================================

SPRING_PROFILES_ACTIVE=prod
APP_VERSION=1.0.0
BACKEND_HOST_PORT=8080
SERVER_CONTEXT_PATH=/api

# Frontend / CORS (REQUERIDOS)
APP_BASE_URL=https://api.edushift.example.com
FRONTEND_URL=https://app.edushift.example.com
CORS_ALLOWED_ORIGINS=https://app.edushift.example.com
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600

# PostgreSQL (REQUERIDOS)
DB_NAME=edushift
DB_USER=<REQUIRED>
DB_PASSWORD=<REQUIRED-from-secret-manager>
DB_SCHEMA=edushift
DB_SSL_MODE=require

# Hikari (prod)
HIKARI_MINIMUM_IDLE=10
HIKARI_MAXIMUM_POOL_SIZE=30

# Flyway
FLYWAY_ENABLED=true
FLYWAY_SCHEMAS=edushift
FLYWAY_DEFAULT_SCHEMA=edushift

# Redis (REQUERIDOS)
REDIS_PASSWORD=<REQUIRED-from-secret-manager>
REDIS_SSL_ENABLED=true
REDIS_KEY_PREFIX=edushift:
REDIS_MAXMEMORY=512mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# JWT (REQUERIDO - generar con: openssl rand -base64 48)
JWT_SECRET=<REQUIRED-from-secret-manager>
JWT_ISSUER=edushift
JWT_AUDIENCE=edushift-clients
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# OpenRouter (REQUERIDO si OPENROUTER_ENABLED=true)
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=<REQUIRED-from-secret-manager>
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=openai/gpt-4o-mini
OPENROUTER_REFERER=https://app.edushift.example.com
OPENROUTER_TITLE=EduShift
OPENROUTER_TIMEOUT=30s
OPENROUTER_MAX_RETRIES=2

# Firebase (REQUERIDO si FIREBASE_ENABLED=true)
# Inyectar UNA de las dos:
#   - FIREBASE_CREDENTIALS_JSON: JSON completo del service-account (ideal en k8s/Vault)
#   - FIREBASE_CREDENTIALS_PATH: ruta a archivo montado como secret
FIREBASE_ENABLED=true
FIREBASE_PROJECT_ID=<REQUIRED>
FIREBASE_CREDENTIALS_JSON=<REQUIRED-from-secret-manager>
FIREBASE_CREDENTIALS_PATH=
FIREBASE_WEB_API_KEY=<REQUIRED-from-secret-manager>
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# Files / Storage provider (docs/infra/firebase.md)
# Producción debe usar FIREBASE. El bucket se crea en Firebase Console al
# provisionar el proyecto EduShift dedicado (project-1ecb3cb0-5e49-49b2-8e5).
# STORAGE_LOCAL_FS_SERVE_FROM_CONTROLLER=false fuerza el patrón 302 → signed URL
# en los GET /api/v1/files/{uuid}/download (los bytes no tocan este servidor).
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=FIREBASE
STORAGE_MAX_FILE_SIZE_BYTES=26214400
STORAGE_LOCAL_FS_ROOT=./edushift-storage
STORAGE_LOCAL_FS_SERVE_FROM_CONTROLLER=false
STORAGE_FIREBASE_BUCKET=edushift-prod-<region>
STORAGE_FIREBASE_CREDENTIALS_JSON=<REQUIRED-from-secret-manager>
STORAGE_FIREBASE_CREDENTIALS_PATH=
STORAGE_FIREBASE_SIGNED_URL_TTL=900

# -----------------------------------------------------------------------------
# Logging (prod: estructurado + rolling files por categoría)
# Asegurar volumen montado / persistente sobre LOG_PATH (kubernetes: PVC).
# -----------------------------------------------------------------------------
LOG_PATH=/var/log/edushift
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=INFO
APP_LOG_LEVEL=INFO
SECURITY_LOG_LEVEL=WARN
SQL_LOGGING_ENABLED=false
HIKARI_LOG_LEVEL=WARN
FLYWAY_LOG_LEVEL=WARN
REDIS_LOG_LEVEL=WARN

# JVM
JAVA_OPTS=-Xms512m -Xmx1536m
